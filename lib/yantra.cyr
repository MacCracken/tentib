# yantra.cyr -- bundled distribution
# Version: 1.0.0
# Generated by: cyrius distlib
# Do not edit -- rebuild with: cyrius distlib

# --- main.cyr ---

# yantra — library entry point.
#
# This file exports the Session / Selector / Action primitives used by
# `.tcyr` test files and the web/mobile backends that fill in later.
# Keep it free of top-level `main()` / syscall(60) — yantra is a
# LIBRARY. `cyrius distlib` concatenates this file (and future
# `src/web.cyr` / `src/mobile.cyr` / `src/protocol/*.cyr`) into
# `dist/yantra.cyr`, which downstream `.tcyr` files include.
#
# Scaffolded 2026-04-23. The session primitives live here first; the
# browser and mobile backends fill in against stdlib `http.cyr` +
# `ws.cyr` + `json.cyr` + `tls.cyr` as each lands. See
# [docs/adr/0001-yantra-is-a-library-not-a-framework.md] for the
# shape decision.

# --- Selector ---------------------------------------------------------------
# Selectors address UI elements. String-based, with a prefix hint:
#   "#id"       CSS id selector
#   ".class"    CSS class selector
#   "@id/name"  Android UiAutomator2 resource-id
#   "~label"    iOS XCUITest accessibility label
#   "text:foo"  visible-text match (browser + mobile)
#   otherwise   generic CSS / XPath (auto-detected by leading `/`)
#
# Selectors are opaque strings here; each backend parses them into its
# own query shape.

# --- Session ----------------------------------------------------------------
# A session is a running browser page or mobile app attached to a
# single target. Consumers get a session by calling
# yantra_web_open(browser) or yantra_mobile_open(platform, package),
# and close it with yantra_close(session).
#
# Layout (24 bytes):
#   +0   kind      (i64: 1=web, 2=mobile)
#   +8   backend   (ptr to backend-specific state)
#   +16  flags     (i64: auto_wait, strict, etc.)
var YANTRA_KIND_WEB    = 1;
var YANTRA_KIND_MOBILE = 2;

fn yantra_session_kind(s)    { return load64(s); }
fn yantra_session_backend(s) { return load64(s + 8); }
fn yantra_session_flags(s)   { return load64(s + 16); }

# --- Placeholder dispatch ---------------------------------------------------
# Real open/navigate/click/type/tap/close land when the web and mobile
# backends do. Current scaffold exports just the stable primitives so
# downstream `.tcyr` consumers can compile against a known surface.

fn yantra_version() {
    return "1.0.0";
}

# --- runtime.cyr ---

# src/runtime.cyr — M5 resilience surface: structured errors, session registry
# (auto-teardown), tracing spans, retry/backoff config, and the shared sleep
# helper. Sits right after main.cyr in the [lib] order so every backend and the
# public verbs can use it.
#
# No `include` directives (bundle-safe). References the stdlib `sakshi` tracing
# symbols (resolved by the consumer / link-check chain), gated behind a flag so
# they're never called unless tracing is on.

# ── structured error surface ────────────
# Every failing verb sets a code + message; consumers read them after a 0/false
# return instead of guessing. Cleared at the start of each top-level action.
var YANTRA_OK           = 0;
var YANTRA_ERR_NULL     = 1;   # null session / argument
var YANTRA_ERR_BROWSER  = 2;   # unknown / unsupported browser or platform
var YANTRA_ERR_CONNECT  = 3;   # could not reach the driver / CDP endpoint
var YANTRA_ERR_SESSION  = 4;   # session create failed (driver rejected caps)
var YANTRA_ERR_NAV      = 5;   # navigation failed
var YANTRA_ERR_NO_ELEMENT = 6; # selector matched nothing (within the wait)
var YANTRA_ERR_ACTION   = 7;   # click / type / eval failed at the protocol
var YANTRA_ERR_VERIFY   = 8;   # sigil signature over a cert-pin descriptor failed

var _yantra_err_code = 0;
var _yantra_err_msg  = 0;

fn _yantra_set_err(code, msg): i64 { _yantra_err_code = code; _yantra_err_msg = msg; return 0; }
fn _yantra_clear_err(): i64 { _yantra_err_code = 0; _yantra_err_msg = 0; return 0; }

# Last error code (YANTRA_OK == none), and its message (cstr).
fn yantra_last_error(): i64 { return _yantra_err_code; }
fn yantra_last_error_str(): i64 {
    if (_yantra_err_msg == 0) { return "ok"; }
    return _yantra_err_msg;
}

# ── monotonic sleep (shared) ────────────
# Portable ms-granular sleep: `poll(NULL, 0, ms)` blocks for `ms` then returns 0.
# `poll` (syscall 7) is rerouted 7→230 on the Mach-O/Darwin backend and is plain
# poll on Linux — the same call cyrius's stdlib `chrono.sleep_ms` uses. The old
# raw `syscall(35)` assumed the x86-Linux nanosleep number; on aarch64 35 is
# `unlinkat`, and cyrius deliberately does NOT route 35 as nanosleep in the
# aarch64 Mach-O ESYSXLAT table, so it faulted the iOS e2e at runtime (exit 127).
# See cyrius issue 2026-06-04-macos-nanosleep-syscall-35-not-in-esysxlat.
fn _yantra_sleep_ms(ms): i64 {
    syscall(7, 0, 0, ms);   # poll(NULL, 0, ms) — portable ms sleep (7→230 Darwin)
    return 0;
}

# ── retry / backoff (resilience) ────────────
# Bounded retry for transient open/connect failures (driver still starting,
# connection reset). Linear backoff. Applied on the open path; configurable.
var _yantra_open_attempts = 4;
var _yantra_open_backoff_ms = 150;
fn yantra_set_open_retry(attempts, backoff_ms): i64 {
    _yantra_open_attempts = attempts;
    _yantra_open_backoff_ms = backoff_ms;
    return 0;
}
fn _yantra_open_attempts_get(): i64 { return _yantra_open_attempts; }
fn _yantra_backoff(attempt): i64 { _yantra_sleep_ms(_yantra_open_backoff_ms * attempt); return 0; }

# ── tracing spans (sakshi) ────────────
# Off by default. When enabled, each action is wrapped in a sakshi span so
# consumers get a visible timeline. Guarded so sakshi is never called unless on.
var _yantra_trace = 0;
fn yantra_trace_enable(on): i64 { _yantra_trace = on; return 0; }
fn yantra_trace_enabled(): i64 { return _yantra_trace; }
fn _yantra_span_enter(name): i64 {
    if (_yantra_trace != 0) { sakshi_span_enter(name, strlen(name)); }
    return 0;
}
fn _yantra_span_exit(): i64 {
    if (_yantra_trace != 0) { sakshi_span_exit(); }
    return 0;
}

# ── session registry (auto-teardown) ────────────
# yantra has no atexit hook to lean on, so leaked browsers/emulators are closed
# by tearing down every registered session at exit. Consumers use
# `yantra_exit(code)` instead of `syscall(60, code)` (or call
# `yantra_teardown_all()` directly). Fixed slot array; freed slots are reused.
var _YANTRA_MAX_SESSIONS = 64;
var _yantra_sessions = 0;
fn _yantra_reg_init(): i64 {
    if (_yantra_sessions == 0) {
        _yantra_sessions = alloc(_YANTRA_MAX_SESSIONS * 8);
        memset(_yantra_sessions, 0, _YANTRA_MAX_SESSIONS * 8);
    }
    return 0;
}
fn _yantra_register(s): i64 {
    _yantra_reg_init();
    var i = 0;
    var done = 0;
    while (i < _YANTRA_MAX_SESSIONS) {
        if (done == 0) {
            if (load64(_yantra_sessions + i * 8) == 0) {
                store64(_yantra_sessions + i * 8, s);
                done = 1;
            }
        }
        i = i + 1;
    }
    return 0;
}
fn _yantra_unregister(s): i64 {
    if (_yantra_sessions == 0) { return 0; }
    var i = 0;
    while (i < _YANTRA_MAX_SESSIONS) {
        if (load64(_yantra_sessions + i * 8) == s) { store64(_yantra_sessions + i * 8, 0); }
        i = i + 1;
    }
    return 0;
}
# Count of currently-registered (open) sessions.
fn yantra_open_session_count(): i64 {
    if (_yantra_sessions == 0) { return 0; }
    var i = 0;
    var n = 0;
    while (i < _YANTRA_MAX_SESSIONS) {
        if (load64(_yantra_sessions + i * 8) != 0) { n = n + 1; }
        i = i + 1;
    }
    return n;
}

# --- security.cyr ---

# src/security.cyr — M8 endpoint transport security: sigil-verified cert pins.
#
# A consumer pointing a yantra session at a REMOTE WebDriver/Appium grid over
# HTTPS wants to pin the endpoint's certificate by its SPKI (Subject Public Key
# Info) SHA-256 hash. Rather than trust a bare hex string, the pin is delivered
# as a descriptor SIGNED with sigil — so a tampered or substituted pin is
# rejected before it is ever applied. These verbs are the crypto gate:
#
#   spki_hex  — the pinned SPKI SHA-256 (hex), i.e. the signed message.
#   ed_sig    — 64-byte Ed25519 signature over spki_hex.
#   ed_pk     — 32-byte Ed25519 public key of the trusted pin signer.
#   mldsa_*   — ML-DSA-65 signature + public key (hybrid PQC variant only).
#
# On a good signature they return a sandhi pinned-cert TLS policy handle
# (sandhi_tls_policy_new_pinned) ready to attach to a connection; on a bad one
# they return 0 and set YANTRA_ERR_VERIFY. Requires sigil in the consumer's
# `[deps] stdlib`.
#
# These are the low-level gate. The web/mobile surfaces wrap them in
# yantra_web_set_tls_pin_ed25519 / yantra_mobile_set_tls_pin_* (0.8.2), which on
# a good signature switch the endpoint to HTTPS and register the returned policy
# via sandhi's endpoint-keyed registry (sandhi_rpc_set_default_tls_policy, sandhi
# 1.6.3) so every per-action call enforces it. Plain-HTTP/localhost endpoints
# ignore the policy, so localhost sessions are unaffected. Tested in
# tests/m8.tcyr; see docs/audit/2026-06-15-audit.md F-2.

# Verify an Ed25519-signed SPKI cert-pin; return a sandhi pinned TLS policy or 0.
fn yantra_tls_pin_verify_ed25519(spki_hex, ed_sig, ed_pk): i64 {
    _yantra_clear_err();
    if (spki_hex == 0) { _yantra_set_err(YANTRA_ERR_NULL, "null spki pin"); return 0; }
    if (ed_sig == 0) { _yantra_set_err(YANTRA_ERR_NULL, "null pin signature"); return 0; }
    if (ed_pk == 0) { _yantra_set_err(YANTRA_ERR_NULL, "null signer key"); return 0; }
    var ok = sigil_verify_hybrid(spki_hex, strlen(spki_hex), ed_sig, ed_pk, 0, 0, SIG_ALG_ED25519);
    if (ok != 1) { _yantra_set_err(YANTRA_ERR_VERIFY, "sigil pin signature did not verify"); return 0; }
    return sandhi_tls_policy_new_pinned(spki_hex);
}

# Hybrid (Ed25519 + ML-DSA-65) variant — both signatures must verify.
fn yantra_tls_pin_verify_hybrid(spki_hex, ed_sig, ed_pk, mldsa_sig, mldsa_pk): i64 {
    _yantra_clear_err();
    if (spki_hex == 0) { _yantra_set_err(YANTRA_ERR_NULL, "null spki pin"); return 0; }
    if (ed_sig == 0 || ed_pk == 0) { _yantra_set_err(YANTRA_ERR_NULL, "null ed25519 sig/key"); return 0; }
    if (mldsa_sig == 0 || mldsa_pk == 0) { _yantra_set_err(YANTRA_ERR_NULL, "null ml-dsa sig/key"); return 0; }
    var ok = sigil_verify_hybrid(spki_hex, strlen(spki_hex), ed_sig, ed_pk, mldsa_sig, mldsa_pk, SIG_ALG_HYBRID);
    if (ok != 1) { _yantra_set_err(YANTRA_ERR_VERIFY, "sigil hybrid pin signature did not verify"); return 0; }
    return sandhi_tls_policy_new_pinned(spki_hex);
}

# --- cdp.cyr ---

# src/protocol/cdp.cyr — Chrome DevTools Protocol over lib/ws.cyr.
#
# The M1 backend. CDP speaks JSON-RPC over a single WebSocket, so this
# module needs only the WebSocket transport (lib/ws.cyr, complete) plus
# a one-shot HTTP GET to discover the page target's debugger URL
# (lib/http.cyr, GET-only — sufficient here). No HTTP POST, no HTTPS, so
# M1 ships ahead of the WebDriver/Appium http.cyr depth gate.
#
# This file carries NO `include` directives: `cyrius distlib` concatenates
# it into `dist/yantra.cyr`, where stdlib symbols (ws_*, http_*, json_v_*,
# str_*, fmt_*, net) are left unresolved and supplied by the consumer's
# `[deps] stdlib`. The link-check program (programs/smoke.cyr) includes the
# stdlib chain ahead of this module so the whole graph type-checks locally.
#
# Outgoing commands are built as raw JSON strings (a small escaper handles
# the dynamic values) — that keeps cstr in / cstr out and feeds
# ws_send_text directly. Incoming responses are parsed with the json.cyr
# tagged-value tree (json_v_parse_str + nested json_v_obj_get), whose
# string values are Str-typed and converted back to cstr via _cdp_s2c.

# ── small string helpers (shared with web.cyr, included after this) ────────────

# Str → freshly-allocated null-terminated cstr. Returns 0 if s is 0.
fn _cdp_s2c(s): i64 {
    if (s == 0) { return 0; }
    var d = str_data(s);
    var n = str_len(s);
    var b = alloc(n + 1);
    memcpy(b, d, n);
    store8(b + n, 0);
    return b;
}

# Append a raw cstr to buf at off; return new off.
fn _cdp_b_cstr(buf, off, s): i64 {
    var n = strlen(s);
    memcpy(buf + off, s, n);
    return off + n;
}

# Append the decimal form of n to buf at off; return new off.
fn _cdp_b_int(buf, off, n): i64 {
    var w = fmt_int_buf(n, buf + off);
    return off + w;
}

# nibble (0..15) -> ASCII hex digit ('0'..'9','a'..'f').
fn _cdp_hex_digit(n): i64 {
    if (n < 10) { return 48 + n; }
    return 87 + n;
}

# Append s to buf at off, JSON-escaped (no surrounding quotes); return off.
# Every byte < 0x20 is escaped: the named short forms (\" \\ \n \r \t) plus a
# \u00XX fallback for the rest of the C0 control range. Leaving a control byte
# (notably 0x1B ESC) unescaped would be both invalid JSON and a terminal-escape
# injection vector — see docs/audit/2026-06-15-audit.md F-1. The byte is masked
# to 0..255 so UTF-8 continuation bytes (>= 0x80) pass through unescaped even if
# load8 sign-extends. Worst-case expansion is 6x; callers size buffers at *6.
fn _cdp_b_esc(buf, off, s): i64 {
    var i = 0;
    var L = strlen(s);
    while (i < L) {
        var c = load8(s + i) & 255;
        if      (c == 34) { store8(buf + off, 92); store8(buf + off + 1, 34);  off = off + 2; }
        elif    (c == 92) { store8(buf + off, 92); store8(buf + off + 1, 92);  off = off + 2; }
        elif    (c == 10) { store8(buf + off, 92); store8(buf + off + 1, 110); off = off + 2; }
        elif    (c == 13) { store8(buf + off, 92); store8(buf + off + 1, 114); off = off + 2; }
        elif    (c ==  9) { store8(buf + off, 92); store8(buf + off + 1, 116); off = off + 2; }
        elif    (c < 32)  {
            store8(buf + off, 92);                              # backslash
            store8(buf + off + 1, 117);                         # u
            store8(buf + off + 2, 48);                          # 0
            store8(buf + off + 3, 48);                          # 0
            store8(buf + off + 4, _cdp_hex_digit(c / 16));
            store8(buf + off + 5, _cdp_hex_digit(c % 16));
            off = off + 6;
        }
        else              { store8(buf + off, c); off = off + 1; }
        i = i + 1;
    }
    return off;
}

# ── CDP handle ────────────
# Layout (40 bytes):
#   +0   ws handle
#   +8   socket fd
#   +16  next message id
#   +24  reserved
#   +32  reserved

fn cdp_ws(cdp): i64 { return load64(cdp); }
fn cdp_fd(cdp): i64 { return load64(cdp + 8); }
fn cdp_next_id(cdp): i64 {
    var id = load64(cdp + 16) + 1;
    store64(cdp + 16, id);
    return id;
}

# ── outgoing command builders ────────────

# {"id":N,"method":"M","params":{}}
fn _cdp_cmd0(id, method): i64 {
    var buf = alloc(256);
    var o = 0;
    o = _cdp_b_cstr(buf, o, "{\"id\":");
    o = _cdp_b_int(buf, o, id);
    o = _cdp_b_cstr(buf, o, ",\"method\":\"");
    o = _cdp_b_cstr(buf, o, method);
    o = _cdp_b_cstr(buf, o, "\",\"params\":{}}");
    store8(buf + o, 0);
    return buf;
}

# {"id":N,"method":"Page.navigate","params":{"url":"..."}}
fn _cdp_cmd_navigate(id, url): i64 {
    var buf = alloc(strlen(url) * 6 + 256);   # *6: worst-case \u00XX escape expansion
    var o = 0;
    o = _cdp_b_cstr(buf, o, "{\"id\":");
    o = _cdp_b_int(buf, o, id);
    o = _cdp_b_cstr(buf, o, ",\"method\":\"Page.navigate\",\"params\":{\"url\":\"");
    o = _cdp_b_esc(buf, o, url);
    o = _cdp_b_cstr(buf, o, "\"}}");
    store8(buf + o, 0);
    return buf;
}

# {"id":N,"method":"Runtime.evaluate","params":{"expression":"JS",
#   "returnByValue":true,"awaitPromise":true}}
fn _cdp_cmd_eval(id, js): i64 {
    var buf = alloc(strlen(js) * 6 + 256);   # *6: worst-case \u00XX escape expansion
    var o = 0;
    o = _cdp_b_cstr(buf, o, "{\"id\":");
    o = _cdp_b_int(buf, o, id);
    o = _cdp_b_cstr(buf, o, ",\"method\":\"Runtime.evaluate\",\"params\":{\"expression\":\"");
    o = _cdp_b_esc(buf, o, js);
    o = _cdp_b_cstr(buf, o, "\",\"returnByValue\":true,\"awaitPromise\":true}}");
    store8(buf + o, 0);
    return buf;
}

# ── send / receive ────────────

# Read frames until a response whose "id" == want arrives; return the
# parsed top-level value (json_v) or 0 on close/timeout. CDP events carry
# no "id" and are skipped. Bounded so a missing reply can't hang forever.
fn _cdp_await(cdp, want): i64 {
    var ws = cdp_ws(cdp);
    var tries = 0;
    var got = 0;
    var res = 0;
    while (tries < 1000) {
        var data = ws_recv(ws);
        if (data == 0) { tries = 1000; continue; }
        var v = json_v_parse_str(data, strlen(data));
        if (v != 0) {
            var idv = json_v_obj_get(v, "id");
            if (idv != 0) {
                if (json_v_is_int(idv) == 1) {
                    if (json_v_int(idv) == want) { res = v; got = 1; tries = 1000; continue; }
                }
            }
        }
        tries = tries + 1;
    }
    if (got == 1) { return res; }
    return 0;
}

# Send a Page.navigate and wait for the command ack. Returns 1 on ack, 0 otherwise.
fn cdp_navigate(cdp, url): i64 {
    var id = cdp_next_id(cdp);
    ws_send_text(cdp_ws(cdp), _cdp_cmd_navigate(id, url));
    if (_cdp_await(cdp, id) == 0) { return 0; }
    return 1;
}

# Runtime.evaluate with returnByValue. Returns the result.result.value
# node (json_v) or 0. Callers pull the typed value with json_v_str / int /
# bool as appropriate.
fn cdp_eval(cdp, js): i64 {
    var id = cdp_next_id(cdp);
    ws_send_text(cdp_ws(cdp), _cdp_cmd_eval(id, js));
    var v = _cdp_await(cdp, id);
    if (v == 0) { return 0; }
    return json_v_obj_get(json_v_obj_get(json_v_obj_get(v, "result"), "result"), "value");
}

# Convenience: evaluate JS expected to yield a string; return it as cstr or 0.
fn cdp_eval_str(cdp, js): i64 {
    var v = cdp_eval(cdp, js);
    if (v == 0) { return 0; }
    return _cdp_s2c(json_v_str(v));
}

# Convenience: evaluate JS expected to yield a boolean; return 1/0.
fn cdp_eval_bool(cdp, js): i64 {
    var v = cdp_eval(cdp, js);
    if (v == 0) { return 0; }
    return json_v_bool(v);
}

# ── connection lifecycle ────────────

# Disable Nagle's algorithm on a socket. CDP is strict request/response over
# loopback, which is the worst case for Nagle + delayed-ACK: small writes get
# held, pinning each round trip near ~40ms. With TCP_NODELAY the round trip
# drops to ~1ms. SYS_SETSOCKOPT=54, IPPROTO_TCP=6, TCP_NODELAY=1.
fn _cdp_set_nodelay(fd): i64 {
    var one = alloc(4);
    store32(one, 1);
    return syscall(54, fd, 6, 1, one, 4);
}

# Minimal HTTP/1.1 GET for the CDP discovery endpoint. The stdlib http_get
# speaks HTTP/1.0, which Chromium's DevTools HTTP server silently rejects
# (it requires HTTP/1.1 — verified: 1.0 gets an empty close, 1.1 gets a
# Content-Length response). Connection: close plus a recv timeout guarantee
# the read loop terminates. Returns an alloc'd {body_ptr, body_len} pair, or 0.
fn _cdp_http_get(port, path): i64 {
    var fd_r = tcp_socket();
    if (is_err_result(fd_r) == 1) { return 0; }
    var fd = payload(fd_r);
    sock_set_recv_timeout(fd, 5, 0);
    var c_r = sock_connect(fd, INADDR_LOOPBACK(), port);
    if (is_err_result(c_r) == 1) { sock_close(fd); return 0; }

    var req = alloc(256);
    var o = _cdp_b_cstr(req, 0, "GET ");
    o = _cdp_b_cstr(req, o, path);
    o = _cdp_b_cstr(req, o, " HTTP/1.1\r\nHost: 127.0.0.1:");
    o = _cdp_b_int(req, o, port);
    o = _cdp_b_cstr(req, o, "\r\nConnection: close\r\nAccept: application/json\r\n\r\n");
    sock_send(fd, req, o);

    var cap = 262144;
    var buf = alloc(cap);
    var total = 0;
    var go = 1;
    while (go == 1) {
        var rd = sock_recv(fd, buf + total, cap - total);
        if (is_err_result(rd) == 1) { go = 0; }
        else {
            var n = payload(rd);
            if (n <= 0) { go = 0; }
            else { total = total + n; if (total >= cap) { go = 0; } }
        }
    }
    sock_close(fd);

    # Body begins after the CRLFCRLF header terminator.
    var i = 0;
    var bodyoff = 0;
    var found = 0;
    while (i + 3 < total) {
        if (found == 0) {
            if (load8(buf + i) == 13) {
                if (load8(buf + i + 1) == 10) {
                    if (load8(buf + i + 2) == 13) {
                        if (load8(buf + i + 3) == 10) { bodyoff = i + 4; found = 1; }
                    }
                }
            }
        }
        i = i + 1;
    }
    if (found == 0) { return 0; }
    var res = alloc(16);
    store64(res, buf + bodyoff);
    store64(res + 8, total - bodyoff);
    return res;
}

# "127.0.0.1:<port>" — the Host header value for the WS handshake.
fn _cdp_host_hdr(port): i64 {
    var buf = alloc(32);
    var o = _cdp_b_cstr(buf, 0, "127.0.0.1:");
    o = _cdp_b_int(buf, o, port);
    store8(buf + o, 0);
    return buf;
}

# Pick a "page" target's webSocketDebuggerUrl from the /json array (json_v).
# Falls back to the first target with any debugger URL. Returns cstr or 0.
fn _cdp_find_page_ws(arr): i64 {
    if (arr == 0) { return 0; }
    var n = json_v_arr_len(arr);
    var i = 0;
    var found = 0;
    var firstws = 0;
    while (i < n) {
        var el = json_v_arr_get(arr, i);
        var wsv = json_v_obj_get(el, "webSocketDebuggerUrl");
        if (wsv != 0) {
            if (firstws == 0) { firstws = wsv; }
            var tv = json_v_obj_get(el, "type");
            if (tv != 0) {
                if (streq(_cdp_s2c(json_v_str(tv)), "page") == 1) { found = wsv; i = n; continue; }
            }
        }
        i = i + 1;
    }
    if (found != 0) { return _cdp_s2c(json_v_str(found)); }
    if (firstws != 0) { return _cdp_s2c(json_v_str(firstws)); }
    return 0;
}

# Extract the path from "ws://host:port/path..." — the bytes from the first
# '/' after the "://" host part. Returns a pointer into wsurl, or "/".
fn _cdp_ws_path(wsurl): i64 {
    var L = strlen(wsurl);
    var i = 0;
    var host = wsurl;
    var seen = 0;
    while (i < L) {
        if (seen == 0) {
            if (i + 2 < L) {
                if (load8(wsurl + i) == 58) {           # ':'
                    if (load8(wsurl + i + 1) == 47) {   # '/'
                        if (load8(wsurl + i + 2) == 47) { # '/'
                            host = wsurl + i + 3;
                            seen = 1;
                        }
                    }
                }
            }
        }
        i = i + 1;
    }
    var j = 0;
    var hl = strlen(host);
    var path = "/";
    var done = 0;
    while (j < hl) {
        if (done == 0) {
            if (load8(host + j) == 47) { path = host + j; done = 1; }
        }
        j = j + 1;
    }
    return path;
}

# Connect to a Chromium DevTools endpoint on 127.0.0.1:<port>. Returns a
# CDP handle (Page domain enabled) or 0 on any failure.
fn cdp_connect(port): i64 {
    var body = _cdp_http_get(port, "/json");
    if (body == 0) { return 0; }
    var arr = json_v_parse_str(load64(body), load64(body + 8));
    var wsurl = _cdp_find_page_ws(arr);
    if (wsurl == 0) { return 0; }
    var path = _cdp_ws_path(wsurl);

    var fd_r = tcp_socket();
    if (is_err_result(fd_r) == 1) { return 0; }
    var fd = payload(fd_r);
    # Backstop so a missing CDP reply can't block ws_recv forever.
    sock_set_recv_timeout(fd, 10, 0);
    var c_r = sock_connect(fd, INADDR_LOOPBACK(), port);
    if (is_err_result(c_r) == 1) { sock_close(fd); return 0; }
    _cdp_set_nodelay(fd);   # kill the ~40ms Nagle/delayed-ACK round-trip tax

    var ws = ws_connect(fd, path, _cdp_host_hdr(port));
    if (ws_state(ws) != WS_OPEN) { sock_close(fd); return 0; }

    var cdp = alloc(40);
    store64(cdp, ws);
    store64(cdp + 8, fd);
    store64(cdp + 16, 0);
    store64(cdp + 24, 0);
    store64(cdp + 32, 0);

    # Enable page lifecycle events (navigate acks, load events).
    var eid = cdp_next_id(cdp);
    ws_send_text(ws, _cdp_cmd0(eid, "Page.enable"));
    _cdp_await(cdp, eid);
    return cdp;
}

# Close the WebSocket and socket. Safe on 0.
fn cdp_close(cdp): i64 {
    if (cdp == 0) { return 0; }
    ws_close(cdp_ws(cdp));
    sock_close(cdp_fd(cdp));
    return 0;
}

# --- webdriver.cyr ---

# src/protocol/webdriver.cyr — W3C WebDriver backend, on sandhi's RPC layer.
#
# The M2 backend (Firefox via geckodriver, WebKit via webkitwebdriver, Chrome
# via chromedriver). As of 0.4.0 this is a thin adapter over the stdlib
# `sandhi` WebDriver dialect (`sandhi_wd_*`) — sandhi 1.4.1 fixed the
# `Connection: close` read path that previously hung against chromium-family
# servers (sandhi `docs/issues/2026-06-03-...`; the in-tree HTTP client this
# replaced is recorded in yantra `docs/architecture/002`). sandhi owns the
# HTTP/1.1+2 transport, TLS, retries, and pooling; yantra owns the verb shape.
#
# Carries NO `include` directives (bundle-safe — see cdp.cyr header). Reuses
# the small builders from cdp.cyr (_cdp_b_cstr / _cdp_b_int), which precede it
# in the [lib] modules order. References the stdlib `sandhi` symbols
# (sandhi_wd_*, sandhi_rpc_*, sandhi_json_*) resolved by the consumer.

# wd handle (16 bytes): +0 base_url cstr, +8 session_id cstr.
fn wd_base(wd): i64 { return load64(wd); }
fn wd_session_id(wd): i64 { return load64(wd + 8); }

# Build a wd handle from an already-opened (base_url, session_id). Used by the
# mobile/Appium backend, which opens via Appium caps but then drives elements
# through the shared WebDriver verbs.
fn wd_handle_new(base, sid): i64 {
    var wd = alloc(16);
    store64(wd, base);
    store64(wd + 8, sid);
    return wd;
}

# Endpoint config for the next wd_connect / wd_connect_timeout. The web and
# mobile open paths set these from their per-surface config right before
# connecting; the defaults reproduce the pre-0.8.2 localhost behaviour exactly
# (http://127.0.0.1, no pin), so localhost sessions are unchanged.
var _wd_host = "127.0.0.1";
var _wd_use_tls = 0;
var _wd_pin_policy = 0;

fn _wd_set_endpoint(host, use_tls, policy): i64 {
    _wd_host = host;
    _wd_use_tls = use_tls;
    _wd_pin_policy = policy;
    return 0;
}

# "http://<host>:<port>" — or "https://…" when TLS is on. sandhi_wd_* take a
# base URL string. Default host/tls give "http://127.0.0.1:<port>" as before.
fn _wd_base_url(port): i64 {
    var buf = alloc(strlen(_wd_host) + 24);
    var o = 0;
    if (_wd_use_tls != 0) { o = _cdp_b_cstr(buf, 0, "https://"); }
    else                  { o = _cdp_b_cstr(buf, 0, "http://"); }
    o = _cdp_b_cstr(buf, o, _wd_host);
    store8(buf + o, 58);   # ':'
    o = o + 1;
    o = _cdp_b_int(buf, o, port);
    store8(buf + o, 0);
    return buf;
}

# Register the verified pin policy (if any) for this base URL so every
# per-action sandhi_wd_* / sandhi_ap_* call to the endpoint enforces it —
# sandhi 1.6.3's endpoint-keyed default TLS-policy registry. No-op when no pin
# is set; plain-HTTP/localhost URLs ignore the policy, so localhost is unchanged.
fn _wd_apply_pin(base): i64 {
    if (_wd_pin_policy != 0) {
        sandhi_rpc_set_default_tls_policy(base, _wd_pin_policy);
    }
    return 0;
}

# Open a session against the driver on <port> with the given capabilities
# JSON. Returns a wd handle (base_url, session_id) or 0 on failure.
fn wd_connect(port, caps_json): i64 {
    var base = _wd_base_url(port);
    _wd_apply_pin(base);
    var resp = sandhi_wd_new_session(base, caps_json);
    if (sandhi_rpc_ok(resp) == 0) { return 0; }
    var sid = sandhi_wd_extract_session_id(resp);
    if (sid == 0) { return 0; }
    var wd = alloc(16);
    store64(wd, base);
    store64(wd + 8, sid);
    return wd;
}

# Diagnostics for the last wd_connect_timeout 0-return, so the failure is
# explainable: a transport/timeout (stage 1/2) reads very differently from a
# bad HTTP status (3) or a body/parse miss (4/5). stage: 0=ok, 1=resp null
# (connect/transport), 2=sandhi err_kind, 3=status out of 2xx, 4=body null,
# 5=no sessionId in body.
var _wd_dbg_stage = 0;
var _wd_dbg_errkind = 0;
var _wd_dbg_status = 0;
fn wd_last_fail_stage(): i64 { return _wd_dbg_stage; }
fn wd_last_fail_errkind(): i64 { return _wd_dbg_errkind; }
fn wd_last_fail_status(): i64 { return _wd_dbg_status; }

# Open a session with an explicit (long) timeout. Mobile session creation —
# Appium installing the UiAutomator2 server / building WebDriverAgent — can take
# 60s+, which blows past sandhi's default RPC timeout (~30s). We POST /session
# via `sandhi_http_post_opts` with a generous read/total budget and parse the
# sessionId ourselves. Returns a wd handle (base, session_id) or 0.
fn wd_connect_timeout(port, caps_json, total_ms): i64 {
    var base = _wd_base_url(port);
    _wd_apply_pin(base);
    var url = alloc(strlen(base) + 16);
    var o = _cdp_b_cstr(url, 0, base);
    o = _cdp_b_cstr(url, o, "/session");
    store8(url + o, 0);

    var h = sandhi_headers_new();
    sandhi_headers_set(h, "Content-Type", "application/json");
    sandhi_headers_set(h, "Accept", "application/json");
    var opts = sandhi_http_options_new();
    # Bounded connect (localhost Appium/driver — 15s is plenty) + a read/total
    # budget sized to the caller's session-open deadline (the iOS POST /session
    # can take minutes while WebDriverAgent builds — see mobile.cyr).
    # sandhi 1.6.2 (bundled in cyrius 6.2.x) Darwin-ported both the non-blocking
    # connect path and SO_RCVTIMEO, closing cyrius issue
    # 2026-06-06-sandhi-nonblocking-connect-not-darwin-ported. These timeouts now
    # apply correctly on macOS, so yantra no longer forces a blocking connect via
    # connect_ms=0 + unset total_ms (the 0.6.2 workaround).
    sandhi_http_options_connect_ms(opts, 15000);
    sandhi_http_options_read_ms(opts, total_ms);
    sandhi_http_options_total_ms(opts, total_ms);

    _wd_dbg_stage = 0;
    _wd_dbg_errkind = 0;
    _wd_dbg_status = 0;
    var resp = sandhi_http_post_opts(url, h, caps_json, strlen(caps_json), opts);
    if (resp == 0) { _wd_dbg_stage = 1; return 0; }
    var ek = sandhi_http_err_kind(resp);
    if (ek != 0) { _wd_dbg_stage = 2; _wd_dbg_errkind = ek; return 0; }
    var st = sandhi_http_status(resp);
    _wd_dbg_status = st;
    if (st < 200) { _wd_dbg_stage = 3; return 0; }
    if (st >= 300) { _wd_dbg_stage = 3; return 0; }
    var body = sandhi_http_body(resp);
    if (body == 0) { _wd_dbg_stage = 4; return 0; }
    var sid = sandhi_json_get_string(body, "value.sessionId");
    if (sid == 0) { sid = sandhi_json_get_string(body, "sessionId"); }
    if (sid == 0) { _wd_dbg_stage = 5; return 0; }
    return wd_handle_new(base, sid);
}

# Navigate to url. Returns 1 on success.
fn wd_navigate(wd, url): i64 {
    return sandhi_rpc_ok(sandhi_wd_navigate_to(wd_base(wd), wd_session_id(wd), url));
}

# Current URL as a cstr, or 0.
fn wd_url(wd): i64 {
    var resp = sandhi_wd_get_url(wd_base(wd), wd_session_id(wd));
    if (sandhi_rpc_ok(resp) == 0) { return 0; }
    return sandhi_json_get_string(sandhi_rpc_body(resp), "value");
}

# Find the first element by strategy ("css selector" / "xpath" / ...).
# Returns the element-id cstr or 0 if not found.
fn wd_find(wd, using, value): i64 {
    var resp = sandhi_wd_find_element(wd_base(wd), wd_session_id(wd), using, value);
    if (sandhi_rpc_ok(resp) == 0) { return 0; }
    return sandhi_wd_extract_element_id(resp);
}

# Click an element by id. Returns 1 on success.
fn wd_click(wd, elem): i64 {
    return sandhi_rpc_ok(sandhi_wd_element_click(wd_base(wd), wd_session_id(wd), elem));
}

# Send keys (type) into an element by id. Returns 1 on success.
fn wd_send_keys(wd, elem, text): i64 {
    return sandhi_rpc_ok(sandhi_wd_element_send_keys(wd_base(wd), wd_session_id(wd), elem, text));
}

# Execute a JS script (W3C /execute/sync); return the value as a cstr, or 0.
fn wd_execute_str(wd, script): i64 {
    var resp = sandhi_wd_execute_script(wd_base(wd), wd_session_id(wd), script, "[]");
    if (sandhi_rpc_ok(resp) == 0) { return 0; }
    return sandhi_json_get_string(sandhi_rpc_body(resp), "value");
}

# Execute a JS script; return the value as an int (callers coerce booleans to
# 0/1 in the script so this reads cleanly).
fn wd_execute_int(wd, script): i64 {
    var resp = sandhi_wd_execute_script(wd_base(wd), wd_session_id(wd), script, "[]");
    if (sandhi_rpc_ok(resp) == 0) { return 0; }
    return sandhi_json_get_int(sandhi_rpc_body(resp), "value");
}

# Delete the session (closes the browser). Safe on 0.
fn wd_close(wd): i64 {
    if (wd == 0) { return 0; }
    sandhi_wd_delete_session(wd_base(wd), wd_session_id(wd));
    return 0;
}

# --- web.cyr ---

# src/web.cyr — yantra's browser-automation public API.
#
# The verbs a `.tcyr` test calls: yantra_web_open / yantra_navigate /
# yantra_click / yantra_click_now / yantra_type / yantra_url / yantra_eval_* /
# yantra_close. Backend selection lives here:
#   "chromium" → CDP backend  (src/protocol/cdp.cyr, over ws.cyr)        [M1]
#   "chrome"   → WebDriver     (chromedriver; src/protocol/webdriver.cyr) [M2]
#   "firefox"  → WebDriver     (geckodriver)                              [M2]
#   "webkit"   → WebDriver     (webkitwebdriver)                          [M2]
# Mobile (Appium) routes in later via the same WebDriver-style HTTP shape.
#
# A session carries a transport tag so the verbs dispatch to the right
# protocol. CDP drives the page by evaluating JS over Runtime.evaluate;
# WebDriver uses native element finding (css selector / xpath) + element
# click/clear/value. Both share Playwright-style auto-waiting.
#
# No `include` directives (see cdp.cyr header) — concatenated into the bundle,
# resolved by the consumer / the link-check program. Depends on main.cyr
# (session primitives), cdp.cyr, and webdriver.cyr (all precede it).

# Session layout (32 bytes): +0 kind, +8 backend ptr, +16 flags, +24 transport.
var YANTRA_FLAG_AUTOWAIT = 1;
var YANTRA_TP_CDP = 1;
var YANTRA_TP_WD  = 2;

fn _web_tp(s): i64 { return load64(s + 24); }

# Connection ports. 0 for the WebDriver port means "use the per-browser
# default" (chromedriver 9515, geckodriver/webkitwebdriver 4444).
var _yantra_cdp_port = 9222;
var _yantra_wd_port  = 0;
fn yantra_web_set_cdp_port(p): i64 { _yantra_cdp_port = p; return 0; }
fn yantra_web_cdp_port(): i64 { return _yantra_cdp_port; }
fn yantra_web_set_wd_port(p): i64 { _yantra_wd_port = p; return 0; }

# Remote WebDriver endpoint (M8). Default 127.0.0.1 — local driver, plain HTTP,
# byte-identical to pre-0.8.2. `set_host` points at a remote grid; a verified
# TLS pin (below) switches it to HTTPS. Only the WebDriver browsers
# (chrome/firefox/webkit/safari) honor these — chromium/CDP is localhost-only.
var _yantra_web_host = "127.0.0.1";
var _yantra_web_tls  = 0;
var _yantra_web_pin_policy = 0;
fn yantra_web_set_host(host): i64 { _yantra_web_host = host; return 0; }
fn yantra_web_host(): i64 { return _yantra_web_host; }

# Pin the WebDriver endpoint cert by a sigil-signed SPKI hash. Verifies the
# signature (Ed25519, or hybrid Ed25519+ML-DSA-65); on success switches the
# endpoint to HTTPS and registers the pin so every per-action call enforces it
# (via sandhi's endpoint-keyed default TLS-policy registry). Returns 1 on a
# good signature, else 0 (YANTRA_ERR_VERIFY). See src/security.cyr.
fn yantra_web_set_tls_pin_ed25519(spki_hex, ed_sig, ed_pk): i64 {
    var pol = yantra_tls_pin_verify_ed25519(spki_hex, ed_sig, ed_pk);
    if (pol == 0) { return 0; }
    _yantra_web_pin_policy = pol;
    _yantra_web_tls = 1;
    return 1;
}
fn yantra_web_set_tls_pin_hybrid(spki_hex, ed_sig, ed_pk, mldsa_sig, mldsa_pk): i64 {
    var pol = yantra_tls_pin_verify_hybrid(spki_hex, ed_sig, ed_pk, mldsa_sig, mldsa_pk);
    if (pol == 0) { return 0; }
    _yantra_web_pin_policy = pol;
    _yantra_web_tls = 1;
    return 1;
}

# ── auto-wait knobs ────────────
# Playwright's defining decision: actions wait for the element to be
# actionable before operating. We poll over the wire rather than sleeping
# blindly. ~1000 tries × 5ms ≈ 5s ceiling.
var _YANTRA_WAIT_TRIES = 1000;
var _YANTRA_WAIT_MS    = 5;

# (auto-wait sleep lives in src/runtime.cyr: _yantra_sleep_ms)

# ── JS expression builders (CDP path) ────────────
# Selector / text are user data embedded in a JS double-quoted string literal,
# so they are JS-escaped here; the whole expression is JSON-escaped again by
# cdp.cyr on the wire. Two layers, each correct for its level.

fn _web_b_jsesc(buf, off, s): i64 {
    var i = 0;
    var L = strlen(s);
    while (i < L) {
        var c = load8(s + i);
        if      (c == 34) { store8(buf + off, 92); store8(buf + off + 1, 34);  off = off + 2; }
        elif    (c == 92) { store8(buf + off, 92); store8(buf + off + 1, 92);  off = off + 2; }
        elif    (c == 10) { store8(buf + off, 92); store8(buf + off + 1, 110); off = off + 2; }
        elif    (c == 13) { store8(buf + off, 92); store8(buf + off + 1, 114); off = off + 2; }
        else              { store8(buf + off, c); off = off + 1; }
        i = i + 1;
    }
    return off;
}

fn _web_js_exists(sel): i64 {
    var buf = alloc(strlen(sel) * 2 + 64);
    var o = _cdp_b_cstr(buf, 0, "(document.querySelector(\"");
    o = _web_b_jsesc(buf, o, sel);
    o = _cdp_b_cstr(buf, o, "\")!=null)");
    store8(buf + o, 0);
    return buf;
}

fn _web_js_click(sel): i64 {
    var buf = alloc(strlen(sel) * 2 + 128);
    var o = _cdp_b_cstr(buf, 0, "(function(){var e=document.querySelector(\"");
    o = _web_b_jsesc(buf, o, sel);
    o = _cdp_b_cstr(buf, o, "\");if(!e)return false;e.click();return true;})()");
    store8(buf + o, 0);
    return buf;
}

fn _web_js_type(sel, text): i64 {
    var buf = alloc((strlen(sel) + strlen(text)) * 2 + 256);
    var o = _cdp_b_cstr(buf, 0, "(function(){var e=document.querySelector(\"");
    o = _web_b_jsesc(buf, o, sel);
    o = _cdp_b_cstr(buf, o, "\");if(!e)return false;e.focus();e.value=\"");
    o = _web_b_jsesc(buf, o, text);
    o = _cdp_b_cstr(buf, o, "\";e.dispatchEvent(new Event(\"input\",{bubbles:true}));");
    o = _cdp_b_cstr(buf, o, "e.dispatchEvent(new Event(\"change\",{bubbles:true}));return true;})()");
    store8(buf + o, 0);
    return buf;
}

# ── transport-agnostic eval ────────────
# `expr` is a bare JS expression. CDP evaluates it directly; WebDriver needs
# an explicit `return`. Each wraps appropriately.

fn _web_eval_str(s, expr): i64 {
    var be = yantra_session_backend(s);
    if (_web_tp(s) == YANTRA_TP_CDP) { return cdp_eval_str(be, expr); }
    var buf = alloc(strlen(expr) + 16);
    var o = _cdp_b_cstr(buf, 0, "return (");
    o = _cdp_b_cstr(buf, o, expr);
    o = _cdp_b_cstr(buf, o, ")");
    store8(buf + o, 0);
    return wd_execute_str(be, buf);
}

fn _web_eval_bool(s, expr): i64 {
    var be = yantra_session_backend(s);
    if (_web_tp(s) == YANTRA_TP_CDP) { return cdp_eval_bool(be, expr); }
    # WebDriver: coerce to 0/1 in-script so the JSON value is a clean int.
    var buf = alloc(strlen(expr) + 24);
    var o = _cdp_b_cstr(buf, 0, "return ((");
    o = _cdp_b_cstr(buf, o, expr);
    o = _cdp_b_cstr(buf, o, ")?1:0)");
    store8(buf + o, 0);
    return wd_execute_int(be, buf);
}

# Does cstr s start with literal lit?
fn _web_sel_starts(s, lit): i64 {
    var i = 0;
    var L = strlen(lit);
    var ok = 1;
    while (i < L) {
        if (load8(s + i) != load8(lit + i)) { ok = 0; i = L; continue; }
        i = i + 1;
    }
    return ok;
}

# Locator strategy for a yantra selector. `is_mobile` picks the default
# strategy (Appium resource-id vs CSS) and the text: dialect:
#   "@id/..."  -> "id"               (Android resource-id / generic id)
#   "~..."     -> "accessibility id"  (iOS a11y / Android content-desc)
#   "/..."     -> "xpath"
#   "text:..." -> mobile "-android uiautomator" / web "xpath"
#   else       -> mobile "id" / web "css selector"
fn _web_sel_using(sel, is_mobile): i64 {
    if (_web_sel_starts(sel, "@id/") == 1) { return "id"; }
    if (load8(sel) == 126) { return "accessibility id"; }
    if (load8(sel) == 47) { return "xpath"; }
    if (_web_sel_starts(sel, "text:") == 1) {
        if (is_mobile == 1) { return "-android uiautomator"; }
        return "xpath";
    }
    if (is_mobile == 1) { return "id"; }
    return "css selector";
}

# The locator value for `sel` under the chosen strategy (strips the prefix,
# builds the text: query form).
fn _web_sel_value(sel, is_mobile): i64 {
    if (_web_sel_starts(sel, "@id/") == 1) { return sel + 4; }
    if (load8(sel) == 126) { return sel + 1; }
    if (_web_sel_starts(sel, "text:") == 1) {
        var t = sel + 5;
        if (is_mobile == 1) {
            var b = alloc(strlen(t) * 2 + 48);
            var o = _cdp_b_cstr(b, 0, "new UiSelector().text(\"");
            o = _web_b_jsesc(b, o, t);
            o = _cdp_b_cstr(b, o, "\")");
            store8(b + o, 0);
            return b;
        }
        var bx = alloc(strlen(t) + 48);
        var ox = _cdp_b_cstr(bx, 0, "//*[contains(text(),'");
        ox = _cdp_b_cstr(bx, ox, t);
        ox = _cdp_b_cstr(bx, ox, "')]");
        store8(bx + ox, 0);
        return bx;
    }
    return sel;
}

fn _web_is_mobile(s): i64 {
    if (yantra_session_kind(s) == YANTRA_KIND_MOBILE) { return 1; }
    return 0;
}

# Poll for a WebDriver element until found, or ceiling. Returns elem-id or 0.
fn _web_wd_wait_find(be, selector, is_mobile): i64 {
    var using = _web_sel_using(selector, is_mobile);
    var value = _web_sel_value(selector, is_mobile);
    var tries = 0;
    var elem = 0;
    while (tries < _YANTRA_WAIT_TRIES) {
        var e = wd_find(be, using, value);
        if (e != 0) { elem = e; tries = _YANTRA_WAIT_TRIES; continue; }
        _yantra_sleep_ms(_YANTRA_WAIT_MS);
        tries = tries + 1;
    }
    return elem;
}

# Poll (CDP) until selector matches an element, or ceiling. Returns 1/0.
fn _web_cdp_wait_selector(be, sel): i64 {
    var tries = 0;
    var ok = 0;
    while (tries < _YANTRA_WAIT_TRIES) {
        if (cdp_eval_bool(be, _web_js_exists(sel)) == 1) { ok = 1; tries = _YANTRA_WAIT_TRIES; continue; }
        _yantra_sleep_ms(_YANTRA_WAIT_MS);
        tries = tries + 1;
    }
    return ok;
}

# Poll until document.readyState === "complete" (both transports).
fn _web_wait_ready(s): i64 {
    var tries = 0;
    var ok = 0;
    while (tries < _YANTRA_WAIT_TRIES) {
        var done = _web_eval_bool(s, "document.readyState===\"complete\"");
        if (done == 1) { ok = 1; tries = _YANTRA_WAIT_TRIES; continue; }
        _yantra_sleep_ms(_YANTRA_WAIT_MS);
        tries = tries + 1;
    }
    return ok;
}

fn _web_autowait(s): i64 { return yantra_session_flags(s) & YANTRA_FLAG_AUTOWAIT; }

# ── capabilities (WebDriver) ────────────

fn _web_caps_chrome(): i64 {
    var b = alloc(256);
    var o = _cdp_b_cstr(b, 0, "{\"capabilities\":{\"alwaysMatch\":{\"browserName\":\"chrome\",");
    o = _cdp_b_cstr(b, o, "\"goog:chromeOptions\":{\"args\":[");
    o = _cdp_b_cstr(b, o, "\"--headless=new\",\"--no-sandbox\",\"--disable-gpu\"]}}}}");
    store8(b + o, 0);
    return b;
}
fn _web_caps_firefox(): i64 {
    var b = alloc(192);
    var o = _cdp_b_cstr(b, 0, "{\"capabilities\":{\"alwaysMatch\":{\"browserName\":\"firefox\",");
    o = _cdp_b_cstr(b, o, "\"moz:firefoxOptions\":{\"args\":[\"-headless\"]}}}}");
    store8(b + o, 0);
    return b;
}
# WebKit rides WebKitGTK's WebKitWebDriver, which advertises browserName
# "WebKitGTK" — so a hardcoded "webkit" (a Playwright-ism, not a WebDriver
# browser name) fails W3C capability matching at New Session. Omit browserName
# entirely: the endpoint already *is* the WebKit browser, so "match whatever
# this driver controls" is both spec-correct and what yantra means by "webkit".
fn _web_caps_webkit(): i64 {
    return "{\"capabilities\":{\"alwaysMatch\":{}}}";
}
# Apple's safaridriver (built into macOS) uses browserName "safari" — distinct
# from Playwright's "webkit" (webkitwebdriver/MiniBrowser). Run the driver with
# `safaridriver -p <port>` (after a one-time `sudo safaridriver --enable`).
fn _web_caps_safari(): i64 {
    return "{\"capabilities\":{\"alwaysMatch\":{\"browserName\":\"safari\"}}}";
}

# ── session construction ────────────

fn _web_session_new_kind(kind, tp, backend): i64 {
    var s = alloc(32);
    store64(s, kind);
    store64(s + 8, backend);
    store64(s + 16, YANTRA_FLAG_AUTOWAIT);
    store64(s + 24, tp);
    return s;
}

fn _web_session_new(tp, backend): i64 {
    var s = alloc(32);
    store64(s, YANTRA_KIND_WEB);
    store64(s + 8, backend);
    store64(s + 16, YANTRA_FLAG_AUTOWAIT);
    store64(s + 24, tp);
    return s;
}

fn _web_wd_port_or(deflt): i64 {
    if (_yantra_wd_port != 0) { return _yantra_wd_port; }
    return deflt;
}

# Connect the CDP backend with bounded retry (driver may be starting). Returns
# a registered session or 0 (with last-error set).
fn _web_open_cdp(port): i64 {
    var attempt = 1;
    var n = _yantra_open_attempts_get();
    var cdp = 0;
    var go = 1;
    while (go == 1) {
        cdp = cdp_connect(port);
        if (cdp != 0) { go = 0; }
        elif (attempt >= n) { go = 0; }
        else { _yantra_backoff(attempt); attempt = attempt + 1; }
    }
    if (cdp == 0) { _yantra_set_err(YANTRA_ERR_CONNECT, "could not connect to Chromium CDP endpoint"); return 0; }
    var s = _web_session_new(YANTRA_TP_CDP, cdp);
    _yantra_register(s);
    return s;
}

# Open a WebDriver session with bounded retry. Returns a registered session or 0.
fn _web_wd_open(port, caps): i64 {
    _wd_set_endpoint(_yantra_web_host, _yantra_web_tls, _yantra_web_pin_policy);
    var attempt = 1;
    var n = _yantra_open_attempts_get();
    var wd = 0;
    var go = 1;
    while (go == 1) {
        wd = wd_connect(port, caps);
        if (wd != 0) { go = 0; }
        elif (attempt >= n) { go = 0; }
        else { _yantra_backoff(attempt); attempt = attempt + 1; }
    }
    if (wd == 0) { _yantra_set_err(YANTRA_ERR_CONNECT, "could not create WebDriver session"); return 0; }
    var s = _web_session_new(YANTRA_TP_WD, wd);
    _yantra_register(s);
    return s;
}

# ── public API ────────────

# Open a browser session. Returns a session handle or 0 on failure (see
# yantra_last_error). Retries transient connect failures; registers the session
# for auto-teardown.
fn yantra_web_open(browser): i64 {
    _yantra_clear_err();
    _yantra_span_enter("yantra.web_open");
    var s = 0;
    if      (streq(browser, "chromium") == 1) { s = _web_open_cdp(_yantra_cdp_port); }
    elif    (streq(browser, "chrome") == 1)   { s = _web_wd_open(_web_wd_port_or(9515), _web_caps_chrome()); }
    elif    (streq(browser, "firefox") == 1)  { s = _web_wd_open(_web_wd_port_or(4444), _web_caps_firefox()); }
    elif    (streq(browser, "webkit") == 1)   { s = _web_wd_open(_web_wd_port_or(4444), _web_caps_webkit()); }
    elif    (streq(browser, "safari") == 1)   { s = _web_wd_open(_web_wd_port_or(4445), _web_caps_safari()); }
    else    { _yantra_set_err(YANTRA_ERR_BROWSER, "unsupported browser (chromium/chrome/firefox/webkit/safari)"); }
    _yantra_span_exit();
    return s;
}

# Navigate to url. With auto-wait, blocks until the document is complete.
fn yantra_navigate(session, url): i64 {
    if (session == 0) { _yantra_set_err(YANTRA_ERR_NULL, "null session"); return 0; }
    _yantra_clear_err();
    _yantra_span_enter("yantra.navigate");
    var be = yantra_session_backend(session);
    var ok = 0;
    if (_web_tp(session) == YANTRA_TP_CDP) { ok = cdp_navigate(be, url); }
    else                                   { ok = wd_navigate(be, url); }
    if (ok == 0) { _yantra_set_err(YANTRA_ERR_NAV, "navigation failed"); }
    elif (_web_autowait(session) != 0) { _web_wait_ready(session); }
    _yantra_span_exit();
    return ok;
}

# Current page URL as a cstr, or 0.
fn yantra_url(session): i64 {
    if (session == 0) { _yantra_set_err(YANTRA_ERR_NULL, "null session"); return 0; }
    var be = yantra_session_backend(session);
    if (_web_tp(session) == YANTRA_TP_CDP) { return cdp_eval_str(be, "location.href"); }
    return wd_url(be);
}

# Locate an element for a WD/mobile session (auto-wait honored). Sets
# YANTRA_ERR_NO_ELEMENT and returns 0 if not found.
fn _web_find_or_err(session, be, selector): i64 {
    var im = _web_is_mobile(session);
    var elem = 0;
    if (_web_autowait(session) != 0) { elem = _web_wd_wait_find(be, selector, im); }
    else                             { elem = wd_find(be, _web_sel_using(selector, im), _web_sel_value(selector, im)); }
    if (elem == 0) { _yantra_set_err(YANTRA_ERR_NO_ELEMENT, "no element matched selector"); }
    return elem;
}

# Click the first element matching selector. With auto-wait, waits for it first.
fn yantra_click(session, selector): i64 {
    if (session == 0) { _yantra_set_err(YANTRA_ERR_NULL, "null session"); return 0; }
    _yantra_clear_err();
    _yantra_span_enter("yantra.click");
    var be = yantra_session_backend(session);
    var r = 0;
    if (_web_tp(session) == YANTRA_TP_CDP) {
        if ((_web_autowait(session) == 0) || (_web_cdp_wait_selector(be, selector) == 1)) {
            r = cdp_eval_bool(be, _web_js_click(selector));
            if (r == 0) { _yantra_set_err(YANTRA_ERR_ACTION, "click failed"); }
        } else { _yantra_set_err(YANTRA_ERR_NO_ELEMENT, "no element matched selector"); }
    } else {
        var elem = _web_find_or_err(session, be, selector);
        if (elem != 0) { r = wd_click(be, elem); if (r == 0) { _yantra_set_err(YANTRA_ERR_ACTION, "click failed"); } }
    }
    _yantra_span_exit();
    return r;
}

# No-wait opt-out: act immediately, no actionability wait.
fn yantra_click_now(session, selector): i64 {
    if (session == 0) { _yantra_set_err(YANTRA_ERR_NULL, "null session"); return 0; }
    var be = yantra_session_backend(session);
    if (_web_tp(session) == YANTRA_TP_CDP) { return cdp_eval_bool(be, _web_js_click(selector)); }
    var im = _web_is_mobile(session);
    var elem = wd_find(be, _web_sel_using(selector, im), _web_sel_value(selector, im));
    if (elem == 0) { _yantra_set_err(YANTRA_ERR_NO_ELEMENT, "no element matched selector"); return 0; }
    return wd_click(be, elem);
}

# Type text into the element matching selector. With auto-wait, waits first.
fn yantra_type(session, selector, text): i64 {
    if (session == 0) { _yantra_set_err(YANTRA_ERR_NULL, "null session"); return 0; }
    _yantra_clear_err();
    _yantra_span_enter("yantra.type");
    var be = yantra_session_backend(session);
    var r = 0;
    if (_web_tp(session) == YANTRA_TP_CDP) {
        if ((_web_autowait(session) == 0) || (_web_cdp_wait_selector(be, selector) == 1)) {
            r = cdp_eval_bool(be, _web_js_type(selector, text));
            if (r == 0) { _yantra_set_err(YANTRA_ERR_ACTION, "type failed"); }
        } else { _yantra_set_err(YANTRA_ERR_NO_ELEMENT, "no element matched selector"); }
    } else {
        var elem = _web_find_or_err(session, be, selector);
        if (elem != 0) {
            r = wd_send_keys(be, elem, text);
            if (r == 0) { _yantra_set_err(YANTRA_ERR_ACTION, "type failed"); }
        }
    }
    _yantra_span_exit();
    return r;
}

# Evaluate a JS expression in the page; string value as cstr (or 0).
fn yantra_eval_str(session, js): i64 {
    if (session == 0) { _yantra_set_err(YANTRA_ERR_NULL, "null session"); return 0; }
    return _web_eval_str(session, js);
}

# Evaluate a JS expression in the page; boolean value (1/0).
fn yantra_eval_bool(session, js): i64 {
    if (session == 0) { _yantra_set_err(YANTRA_ERR_NULL, "null session"); return 0; }
    return _web_eval_bool(session, js);
}

# Close the session and its underlying transport. Unregisters it from the
# auto-teardown set. Safe on 0.
fn yantra_close(session): i64 {
    if (session == 0) { return 0; }
    _yantra_unregister(session);
    var be = yantra_session_backend(session);
    if (_web_tp(session) == YANTRA_TP_CDP) { cdp_close(be); }
    else                                   { wd_close(be); }
    return 0;
}

# --- mobile.cyr ---

# src/mobile.cyr — yantra's mobile-automation public API (M3: Android Appium).
#
# Appium is W3C WebDriver + mobile extensions, so a mobile session is a
# WebDriver-transport session (transport = YANTRA_TP_WD) whose backend is the
# shared wd handle. Element interaction reuses the WebDriver verbs in
# webdriver.cyr (find/click/send_keys) and the transport-aware verbs in
# web.cyr — `yantra_type`, `yantra_close`, `yantra_eval_*` work unchanged on a
# mobile session. This file adds only what's mobile-specific: the Appium
# session opener and `yantra_tap`. iOS (M4) shares the path via "ios".
#
# Sessions open through `sandhi_wd_new_session` with Appium capabilities built
# here (platformName / appium:automationName / appium:appPackage|bundleId).
# We build caps directly rather than via `sandhi_ap_new_session`, which nests
# extra caps under a non-standard `appium:extras` key.
#
# No `include` directives (bundle-safe). Depends on main.cyr (YANTRA_KIND_MOBILE),
# webdriver.cyr (wd_*), and web.cyr (session/selector/auto-wait helpers) — all
# precede it in the [lib] modules order — plus the stdlib `sandhi` RPC layer.

# Appium server port (default 4723). Override before yantra_mobile_open.
var _yantra_appium_port = 4723;
fn yantra_mobile_set_port(p): i64 { _yantra_appium_port = p; return 0; }
fn yantra_mobile_port(): i64 { return _yantra_appium_port; }

# Remote Appium endpoint (M8). Default 127.0.0.1 — local Appium, plain HTTP,
# byte-identical to pre-0.8.2. `set_host` points at a remote Appium/cloud
# device farm; a verified TLS pin switches it to HTTPS.
var _yantra_mobile_host = "127.0.0.1";
var _yantra_mobile_tls  = 0;
var _yantra_mobile_pin_policy = 0;
fn yantra_mobile_set_host(host): i64 { _yantra_mobile_host = host; return 0; }
fn yantra_mobile_host(): i64 { return _yantra_mobile_host; }

# Pin the Appium endpoint cert by a sigil-signed SPKI hash (Ed25519 / hybrid),
# mirroring the web verbs. On a good signature: switch to HTTPS + register the
# pin so every per-action call enforces it. Returns 1 / 0 (YANTRA_ERR_VERIFY).
fn yantra_mobile_set_tls_pin_ed25519(spki_hex, ed_sig, ed_pk): i64 {
    var pol = yantra_tls_pin_verify_ed25519(spki_hex, ed_sig, ed_pk);
    if (pol == 0) { return 0; }
    _yantra_mobile_pin_policy = pol;
    _yantra_mobile_tls = 1;
    return 1;
}
fn yantra_mobile_set_tls_pin_hybrid(spki_hex, ed_sig, ed_pk, mldsa_sig, mldsa_pk): i64 {
    var pol = yantra_tls_pin_verify_hybrid(spki_hex, ed_sig, ed_pk, mldsa_sig, mldsa_pk);
    if (pol == 0) { return 0; }
    _yantra_mobile_pin_policy = pol;
    _yantra_mobile_tls = 1;
    return 1;
}

# Optional iOS simulator target (appium:deviceName / appium:platformVersion).
# XCUITest needs a concrete simulator; set these before opening an "ios" session
# when the default pick isn't right. 0 = omit (let Appium choose).
var _yantra_ios_device = 0;
var _yantra_ios_version = 0;
fn yantra_mobile_set_ios_device(name, version): i64 {
    _yantra_ios_device = name;
    _yantra_ios_version = version;
    return 0;
}

# Optional iOS simulator UDID (appium:udid). When the target sim is already
# booted, pinning the exact UDID makes Appium attach to *that* instance instead
# of resolving deviceName/platformVersion to a (possibly different, un-booted)
# duplicate and re-running its boot monitor. 0 = omit.
var _yantra_ios_udid = 0;
fn yantra_mobile_set_ios_udid(udid): i64 {
    _yantra_ios_udid = udid;
    return 0;
}

# WebDriverAgent launch budget (appium:wdaLaunchTimeout, ms). Appium's default
# is 60s, but the FIRST WDA launch builds WebDriverAgent via xcodebuild, which
# routinely exceeds it cold — Appium then SIGTERMs the build and the session
# fails (`/status` from WDA :8100 never arrived). A cold build on a hosted CI
# runner measured ~230s, so default to 6 min (Appium won't quit WDA before
# yantra quits the session, whose budget is 7 min — see yantra_mobile_open).
# Override down for fast/prebuilt WDA.
var _yantra_ios_wda_timeout = 360000;
fn yantra_mobile_set_ios_wda_launch_timeout(ms): i64 {
    _yantra_ios_wda_timeout = ms;
    return 0;
}

# Run the iOS simulator headless (appium:isHeadless). Without it, Appium insists
# on a VISIBLE Simulator UI: if the sim was pre-booted headless (e.g. `simctl
# boot` in CI) it logs "booted while its UI is not visible. Trying to restart it
# with the Simulator window visible", launches Simulator.app, then waits for boot
# — which times out ("failed to finish booting after 120s") on a display-less
# runner. Headless skips the visible-UI restart entirely. 0 = omit (let Appium
# show the UI — fine for a developer Mac with a display). Set 1 for headless CI.
var _yantra_ios_headless = 0;
fn yantra_mobile_set_ios_headless(on): i64 {
    _yantra_ios_headless = on;
    return 0;
}

# Skip Appium's app-reset on session start (appium:noReset). The reset
# (terminate + scrub the target app) can silently hang for minutes on hosted CI
# even when there is nothing to reset, and is pointless for read-only / system-app
# smokes. 0 = omit (Appium's default reset). Applies to android + ios.
var _yantra_no_reset = 0;
fn yantra_mobile_set_no_reset(on): i64 {
    _yantra_no_reset = on;
    return 0;
}

# Use a PREBUILT WebDriverAgent instead of building it via xcodebuild at session
# time (appium:usePreinstalledWDA + appium:prebuiltWDAPath). The cold xcodebuild
# WDA build is slow (~4 min) and flaky on hosted CI; prebuilding it once
# (`appium driver run xcuitest download-wda -- --outdir=DIR --kind=sim
# --platform=ios`) and pointing here at DIR/WebDriverAgentRunner-Runner.app makes
# session-create fast + deterministic. Requires iOS 17+/WDA v13+. 0 = omit (Appium
# builds WDA itself).
var _yantra_ios_prebuilt_wda = 0;
fn yantra_mobile_set_ios_prebuilt_wda(app_path): i64 {
    _yantra_ios_prebuilt_wda = app_path;
    return 0;
}

# Build the W3C capabilities JSON for an Appium session. Returns a cstr or 0
# for an unsupported platform. app_id is the Android package or iOS bundle id.
fn _mobile_caps(platform, app_id): i64 {
    var pn = 0;
    var an = 0;
    var android = 0;
    if (streq(platform, "android") == 1) { pn = "Android"; an = "UiAutomator2"; android = 1; }
    elif (streq(platform, "ios") == 1)   { pn = "iOS"; an = "XCUITest"; android = 0; }
    else { return 0; }

    var always = sandhi_json_obj_new();
    sandhi_json_add_string(always, "platformName", pn);
    sandhi_json_add_string(always, "appium:automationName", an);
    if (_yantra_no_reset != 0) { sandhi_json_add_raw(always, "appium:noReset", "true"); }
    if (android == 1) {
        sandhi_json_add_string(always, "appium:appPackage", app_id);
        # Skip the io.appium.settings helper install/launch — it fails to
        # register on some emulator images ("io.appium.settings unavailable",
        # START result -92) and crashes session creation. The UiAutomator2
        # server (which drives find/click/source) is separate and unaffected.
        sandhi_json_add_raw(always, "appium:skipDeviceInitialization", "true");
        sandhi_json_add_raw(always, "appium:disableWindowAnimation", "true");
    } else {
        sandhi_json_add_string(always, "appium:bundleId", app_id);
        if (_yantra_ios_device != 0)  { sandhi_json_add_string(always, "appium:deviceName", _yantra_ios_device); }
        if (_yantra_ios_version != 0) { sandhi_json_add_string(always, "appium:platformVersion", _yantra_ios_version); }
        if (_yantra_ios_udid != 0)    { sandhi_json_add_string(always, "appium:udid", _yantra_ios_udid); }
        if (_yantra_ios_wda_timeout > 0) {
            sandhi_json_add_int(always, "appium:wdaLaunchTimeout", _yantra_ios_wda_timeout);
        }
        if (_yantra_ios_headless != 0) { sandhi_json_add_raw(always, "appium:isHeadless", "true"); }
        if (_yantra_ios_prebuilt_wda != 0) {
            sandhi_json_add_raw(always, "appium:usePreinstalledWDA", "true");
            sandhi_json_add_string(always, "appium:prebuiltWDAPath", _yantra_ios_prebuilt_wda);
        }
    }

    var caps = sandhi_json_obj_new();
    sandhi_json_add_object(caps, "alwaysMatch", always);
    var root = sandhi_json_obj_new();
    sandhi_json_add_object(root, "capabilities", caps);
    return sandhi_json_build(root);
}

# Open a mobile session. platform is "android" (UiAutomator2) or "ios"
# (XCUITest); app_id is the package / bundle id. Connects to a local Appium
# server on the configured port. Returns a session handle or 0 on failure.
fn yantra_mobile_open(platform, app_id): i64 {
    _yantra_clear_err();
    _yantra_span_enter("yantra.mobile_open");
    var caps = _mobile_caps(platform, app_id);
    if (caps == 0) {
        _yantra_set_err(YANTRA_ERR_BROWSER, "unsupported platform (android/ios)");
        _yantra_span_exit();
        return 0;
    }
    # Bounded retry. Mobile session creation can take minutes on first use
    # (Appium installs the UiAutomator2 server / builds WebDriverAgent via
    # xcodebuild), which exceeds sandhi's default RPC timeout — so we use
    # wd_connect_timeout with a 7-min budget. It must outlast the iOS
    # appium:wdaLaunchTimeout (default 6 min) so Appium finishes the WDA build
    # before yantra gives up on the POST /session.
    _wd_set_endpoint(_yantra_mobile_host, _yantra_mobile_tls, _yantra_mobile_pin_policy);
    var attempt = 1;
    var n = _yantra_open_attempts_get();
    var wd = 0;
    var go = 1;
    while (go == 1) {
        wd = wd_connect_timeout(_yantra_appium_port, caps, 420000);
        if (wd != 0) { go = 0; }
        elif (attempt >= n) { go = 0; }
        else { _yantra_backoff(attempt); attempt = attempt + 1; }
    }
    if (wd == 0) {
        # Detailed reason so a 0-return is diagnosable (transport/timeout vs HTTP
        # status vs parse). stage: 1=resp null, 2=err_kind, 3=status, 4=body null,
        # 5=no sessionId. See wd_connect_timeout.
        var msg = alloc(128);
        var mo = _cdp_b_cstr(msg, 0, "Appium session create failed (stage=");
        mo = _cdp_b_int(msg, mo, wd_last_fail_stage());
        mo = _cdp_b_cstr(msg, mo, " errkind=");
        mo = _cdp_b_int(msg, mo, wd_last_fail_errkind());
        mo = _cdp_b_cstr(msg, mo, "/");
        mo = _cdp_b_cstr(msg, mo, sandhi_err_kind_name(wd_last_fail_errkind()));
        mo = _cdp_b_cstr(msg, mo, " status=");
        mo = _cdp_b_int(msg, mo, wd_last_fail_status());
        mo = _cdp_b_cstr(msg, mo, ")");
        store8(msg + mo, 0);
        _yantra_set_err(YANTRA_ERR_SESSION, msg);
        _yantra_span_exit();
        return 0;
    }
    var s = _web_session_new_kind(YANTRA_KIND_MOBILE, YANTRA_TP_WD, wd);
    _yantra_register(s);
    _yantra_span_exit();
    return s;
}

# Tap the element matching selector. Mobile selectors:
#   "@id/<resource-id>"  ·  "~<accessibility-id>"  ·  "text:<text>"  ·  "/<xpath>"
# With auto-wait, waits for the element to exist first. Returns 1/0.
fn yantra_tap(session, selector): i64 {
    if (session == 0) { _yantra_set_err(YANTRA_ERR_NULL, "null session"); return 0; }
    _yantra_clear_err();
    _yantra_span_enter("yantra.tap");
    var be = yantra_session_backend(session);
    var elem = 0;
    if (_web_autowait(session) != 0) { elem = _web_wd_wait_find(be, selector, 1); }
    else                             { elem = wd_find(be, _web_sel_using(selector, 1), _web_sel_value(selector, 1)); }
    var r = 0;
    if (elem == 0) { _yantra_set_err(YANTRA_ERR_NO_ELEMENT, "no element matched selector"); }
    else {
        r = wd_click(be, elem);
        if (r == 0) { _yantra_set_err(YANTRA_ERR_ACTION, "tap failed"); }
    }
    _yantra_span_exit();
    return r;
}

# No-wait opt-out: tap immediately, no actionability wait.
fn yantra_tap_now(session, selector): i64 {
    if (session == 0) { return 0; }
    var be = yantra_session_backend(session);
    var elem = wd_find(be, _web_sel_using(selector, 1), _web_sel_value(selector, 1));
    if (elem == 0) { return 0; }
    return wd_click(be, elem);
}

# The current UI hierarchy as an XML cstr (Appium page source), or 0.
fn yantra_mobile_source(session): i64 {
    if (session == 0) { _yantra_set_err(YANTRA_ERR_NULL, "null session"); return 0; }
    var be = yantra_session_backend(session);
    var resp = sandhi_ap_source(wd_base(be), wd_session_id(be));
    if (sandhi_rpc_ok(resp) == 0) { return 0; }
    return sandhi_json_get_string(sandhi_rpc_body(resp), "value");
}

# ── auto-teardown (M5) ────────────
# Close every open (registered) session — leaked browsers/emulators get shut
# down even if a test bailed early. yantra has no atexit hook to lean on, so
# call this explicitly (or use yantra_exit). `yantra_close` zeroes each slot.
fn yantra_teardown_all(): i64 {
    if (_yantra_sessions == 0) { return 0; }
    var i = 0;
    while (i < _YANTRA_MAX_SESSIONS) {
        var s = load64(_yantra_sessions + i * 8);
        if (s != 0) { yantra_close(s); }
        i = i + 1;
    }
    return 0;
}

# Tear down all open sessions, then exit with `code`. Use in place of
# `syscall(60, code)` so leaked sessions are always closed, pass or fail:
#   var rc = run_test(); yantra_exit(rc);
fn yantra_exit(code): i64 {
    yantra_teardown_all();
    syscall(60, code);
    return code;
}
